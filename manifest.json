{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "2.6.0",
  "description": "__MSG_extDesc__",
  "default_locale": "ru",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "clipboardRead"
  ],
  "commands": {
    "spellcheck": {
      "suggested_key": { "default": "Alt+R", "mac": "Alt+R" },
      "description": "Исправить ошибки"
    },
    "style": {
      "suggested_key": { "default": "Alt+Y", "mac": "Alt+Y" },
      "description": "Переписать текст"
    },
    "emoji": {
      "suggested_key": { "default": "Alt+T", "mac": "Alt+T" },
      "description": "Подобрать эмодзи"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "dist/icons.js", 
        "dist/content.js"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "https://api.mistral.ai/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "AI Spell & Emoji",
    "default_popup": "popup.html" 
  }
}