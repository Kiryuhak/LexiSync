{
  "manifest_version": 3,
  "name": "AI Spell & Emoji",
  "version": "1.1.1",
  "description": "Проверка орфографии, подбор эмодзи и улучшение стиля текста.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "AI Spell & Emoji",
    "default_icon": "icons/icon128.png"
  },
  "commands": {
    "check_text_shortcut": {
      "suggested_key": { "default": "Alt+R", "mac": "Alt+R" },
      "description": "Проверить орфографию"
    },
    "suggest_emoji_shortcut": {
      "suggested_key": { "default": "Alt+T", "mac": "Alt+T" },
      "description": "Подобрать эмодзи"
    },
    "rephrase_shortcut": {
      "suggested_key": { "default": "Alt+U", "mac": "Alt+U" },
      "description": "Другими словами"
    },
    "style_shortcut": {
      "suggested_key": { "default": "Alt+Y", "mac": "Alt+Y" },
      "description": "Улучшить стиль"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}