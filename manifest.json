{
  "manifest_version": 3,
  "name": "LLM Spell & Emoji Assistant",
  "version": "1.0.8",
  "description": "Умная проверка орфографии и подбор эмодзи через Gemini 3.1 Flash-Lite.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "commands": {
    "check_text_shortcut": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "Alt+R"
      },
      "description": "Проверить выделенный текст"
    },
    "suggest_emoji_shortcut": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Подобрать эмодзи"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}