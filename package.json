{
  "name": "lexisync-extension",
  "version": "2.10.0",
  "description": "Умный помощник для работы с текстом на базе Mistral AI",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox",
    "zip": "npm run zip:chrome && npm run zip:firefox",
    "zip:chrome": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "tsc --noEmit",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kiryuhak/LexiSync.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Kiryuhak/LexiSync/issues"
  },
  "homepage": "https://github.com/Kiryuhak/LexiSync#readme",
  "overrides": {
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.0",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "wxt": "^0.20.27"
  }
}
